{
  "manifest_version": 3,
  "name": "AccessBrowse",
  "version": "1.0.0",
  "description": "Browse the web with your voice using Gemini AI",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "sidePanel",
    "offscreen",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.bundle.js"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open AccessBrowse"
  }
}
